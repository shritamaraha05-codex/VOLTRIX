# .env.example — VOLTRIX Free Stack
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Postgres (Supabase free tier) ─────────────────────────────────────────────
# Get from: supabase.com → project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ── Google Cloud (BigQuery — free tier, no billing needed for this scale) ─────
GCP_PROJECT=your-gcp-project-id
# Path to service account JSON (local dev only — Cloud Run uses its own identity)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Gemini (FREE via Google AI Studio — no credit card) ───────────────────────
# Get key at: https://aistudio.google.com/app/apikey
# Free limits: 15 req/min, 1500 req/day on gemini-2.0-flash — more than enough
GEMINI_API_KEY=AIza...

# ── SMTP (email delivery via Gmail / any SMTP provider) ───────────────────────
# Gmail: use a 16-character App Password (not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app
